# =========================================================================
# TrankaPortal — variables de entorno
# Copiá este archivo a .env.local y completá los valores reales.
# NUNCA commitees .env.local (está en .gitignore).
# =========================================================================

# ---- App ----------------------------------------------------------------
# URL pública de la app (usada en emails, redirects, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ---- Base de datos: Supabase Postgres -----------------------------------
# DATABASE_URL: se usa desde el cliente Prisma en runtime.
#   Ir al proyecto Supabase → Settings → Database → Connection string → "Transaction pooler" (puerto 6543).
#   Agregar ?pgbouncer=true&connection_limit=1 al final.
DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-xxx.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# DIRECT_URL: se usa SOLO para migraciones (prisma migrate).
#   Mismo panel → "Session pooler" (puerto 5432) o "Direct connection".
DIRECT_URL="postgresql://postgres.xxxx:password@aws-0-xxx.pooler.supabase.com:5432/postgres"


# ---- Supabase (cliente JS para Storage, signed URLs) --------------------
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...public-anon-key...

# Service role key (server-only, NUNCA exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service-role-key...


# ---- Clerk (auth + Organizations) ---------------------------------------
# Dashboard Clerk → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxx

# Secreto para verificar webhooks entrantes (user.created, org.created, etc.)
# Dashboard Clerk → Webhooks → endpoint → Signing secret
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxxxxxxxxxxx

# Rutas de auth (Clerk las respeta automáticamente si están seteadas)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/


# ---- Resend (emails transaccionales) ------------------------------------
# Dashboard Resend → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx
# Remitente verificado en Resend (tenés que verificar el dominio primero)
RESEND_FROM_EMAIL="TrankaPortal <noreply@tudominio.com>"
