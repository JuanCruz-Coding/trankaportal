// TrankaPortal — schema de base de datos
// Todo modelo tenant lleva organizationId + @@index([organizationId]).
// Clerk es fuente de verdad para roles; NO se replican en DB.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =========================================================================
// TENANT / BILLING
// =========================================================================

model Organization {
  id                       String   @id @default(cuid())
  clerkOrgId               String   @unique
  name                     String
  slug                     String   @unique
  timezone                 String   @default("America/Argentina/Buenos_Aires")
  defaultAnnualTimeOffDays Int      @default(14)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscription      Subscription?
  employees         Employee[]
  departments       Department[]
  positions         Position[]
  documents         Document[]
  timeOffTypes      TimeOffType[]
  timeOffRequests   TimeOffRequest[]
  timeOffBalances   TimeOffBalance[]
  attendanceRecords AttendanceRecord[]
  notifications     Notification[]
}

model Plan {
  id           String  @id @default(cuid())
  key          String  @unique // "starter" | "pro" | "business"
  name         String
  maxEmployees Int? // null = ilimitado
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  features      PlanFeature[]
  subscriptions Subscription[]
}

model Feature {
  id          String  @id @default(cuid())
  key         String  @unique // "employees" | "self-service" | "time-off" | "attendance"
  name        String
  description String?

  plans PlanFeature[]
}

model PlanFeature {
  planId    String
  featureId String

  plan    Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  feature Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@id([planId, featureId])
  @@index([featureId])
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  PAST_DUE
  CANCELLED
}

model Subscription {
  id             String             @id @default(cuid())
  organizationId String             @unique
  planId         String
  status         SubscriptionStatus @default(ACTIVE)

  startedAt DateTime  @default(now())
  endedAt   DateTime?

  // Placeholders para Stripe (no se usan todavía)
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         Plan         @relation(fields: [planId], references: [id])

  @@index([planId])
}

// =========================================================================
// EMPLEADOS
// =========================================================================

enum ContractType {
  FULL_TIME
  PART_TIME
  CONTRACTOR
  INTERN
}

model Employee {
  id             String  @id @default(cuid())
  organizationId String
  // Nullable: HR puede crear Employee antes de que la persona acepte la invitación.
  // El webhook organizationMembership.created linkea el clerkUserId por email.
  clerkUserId    String? @unique

  // Datos personales
  firstName String
  lastName  String
  email     String // espejo del email de Clerk
  dni       String?
  phone     String?
  birthDate DateTime?
  address   String?

  // Datos laborales (nullables: se completan después del webhook de alta)
  positionId   String?
  departmentId String?
  hireDate     DateTime?
  contractType ContractType?
  salary       Decimal?      @db.Decimal(12, 2)
  managerId    String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  position     Position?    @relation(fields: [positionId], references: [id])
  department   Department?  @relation(fields: [departmentId], references: [id])
  manager      Employee?    @relation("EmployeeManager", fields: [managerId], references: [id])
  subordinates Employee[]   @relation("EmployeeManager")

  documents         Document[]
  timeOffRequests   TimeOffRequest[]
  reviewedRequests  TimeOffRequest[]   @relation("TimeOffReviewer")
  timeOffBalances   TimeOffBalance[]
  attendanceRecords AttendanceRecord[]
  notifications     Notification[]

  @@unique([organizationId, email])
  @@unique([organizationId, dni])
  @@index([organizationId])
  @@index([organizationId, isActive])
  @@index([managerId])
}

model Department {
  id             String  @id @default(cuid())
  organizationId String
  name           String
  description    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employees    Employee[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Position {
  id             String  @id @default(cuid())
  organizationId String
  title          String
  description    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employees    Employee[]

  @@unique([organizationId, title])
  @@index([organizationId])
}

// =========================================================================
// DOCUMENTOS
// =========================================================================

enum DocumentType {
  CONTRACT
  DNI
  PAYSLIP
  OTHER
}

model Document {
  id             String @id @default(cuid())
  organizationId String
  employeeId     String

  name        String
  type        DocumentType @default(OTHER)
  storagePath String // path en Supabase Storage (no URL pública)
  mimeType    String?
  sizeBytes   Int?

  uploadedByClerkUserId String?
  uploadedAt            DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([employeeId])
}

// =========================================================================
// TIME-OFF
// =========================================================================

model TimeOffType {
  id             String @id @default(cuid())
  organizationId String

  key              String // "vacation" | "sick" | "personal"
  name             String
  affectsBalance   Boolean @default(true) // vacation sí, sick no
  requiresApproval Boolean @default(true)
  colorHex         String? // para el calendario

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requests     TimeOffRequest[]

  @@unique([organizationId, key])
  @@index([organizationId])
}

enum TimeOffRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model TimeOffRequest {
  id             String @id @default(cuid())
  organizationId String
  employeeId     String
  typeId         String

  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  totalDays Int // días hábiles solicitados (calculado al crear, permite ajustes manuales)
  reason    String?

  status               TimeOffRequestStatus @default(PENDING)
  reviewedByEmployeeId String?
  reviewedAt           DateTime?
  reviewNote           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type         TimeOffType  @relation(fields: [typeId], references: [id])
  reviewer     Employee?    @relation("TimeOffReviewer", fields: [reviewedByEmployeeId], references: [id])

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([employeeId])
  @@index([reviewedByEmployeeId])
}

model TimeOffBalance {
  id             String @id @default(cuid())
  organizationId String
  employeeId     String

  year      Int
  totalDays Int // asignados al año
  usedDays  Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, year])
  @@index([organizationId])
}

// =========================================================================
// ATTENDANCE
// =========================================================================

model AttendanceRecord {
  id             String @id @default(cuid())
  organizationId String
  employeeId     String

  date         DateTime  @db.Date // día calendario en la TZ de la org
  checkIn      DateTime // timestamp UTC
  checkOut     DateTime? // UTC; null = todavía en curso
  totalMinutes Int? // denormalizado al cerrar el día
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([organizationId])
  @@index([organizationId, date])
}

// =========================================================================
// NOTIFICATIONS (centro de actividad in-app)
// =========================================================================

enum NotificationType {
  TIME_OFF_REQUESTED
  TIME_OFF_APPROVED
  TIME_OFF_REJECTED
  TIME_OFF_CANCELLED
  DOCUMENT_UPLOADED
  WELCOME
}

model Notification {
  id                  String           @id @default(cuid())
  organizationId      String
  recipientEmployeeId String

  type  NotificationType
  title String
  body  String?
  link  String? // destino al clickear (ej. "/dashboard/time-off")

  // Referencias para deduplicar / enlazar al origen
  relatedTimeOffRequestId String?
  relatedDocumentId       String?

  readAt    DateTime? // null = no leída
  createdAt DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  recipient    Employee     @relation(fields: [recipientEmployeeId], references: [id], onDelete: Cascade)

  @@index([recipientEmployeeId, readAt])
  @@index([recipientEmployeeId, createdAt(sort: Desc)])
  @@index([organizationId])
}
